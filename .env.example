# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
AFFINDA_API_KEY=your_affinda_api_key
AFFINDA_WORKSPACE_ID=your_affinda_workspace_id

# JWT Secret for WordPress Authentication
# Server-side only - NEVER expose to client!
JWT_SECRET=your_jwt_secret_here

# REMOVED: NEXT_PUBLIC_JWT_SECRET (security risk - was exposed to client)
# Token verification now happens server-side only
