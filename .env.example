# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# JWT Secret for WordPress Authentication
# Server-side only - NEVER expose to client!
JWT_SECRET=your_jwt_secret_here

# REMOVED: NEXT_PUBLIC_JWT_SECRET (security risk - was exposed to client)
# Token verification now happens server-side only

# Upstash Redis for Rate Limiting
# Get these from: https://console.upstash.com (free tier available)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
